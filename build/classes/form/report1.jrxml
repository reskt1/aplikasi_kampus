	<queryString language="SQL">
		<![CDATA[SELECT n.nim, mhs.nama_mhs,mk.kdMatkul,mk.namaMatkul,mk.sks,n.nilaiMutu AS NM,b.bobot,(mk.sks * b.bobot) AS Mutu FROM nilai n JOIN mahasiswa mhs ON n.nim = mhs.nim JOIN dosen_mengajar dm ON n.id_mengajar = dm.id_mengajar JOIN matakuliah mk ON dm.kdMatkul = mk.kdMatkul JOIN bobot b ON n.nilaiMutu = b.nilaiMutu]]>
	</queryString>
